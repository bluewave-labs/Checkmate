					"simStepDescription": "The user navigates to the \"/uptime/bulk-import\" URL, which is routed to the BulkImport component for rendering the UI.",
					"isEdge": 0,
					"sourceCodeMapping": {
						"filePath": "client/src/Routes/index.jsx",
						"startLine": "88",
