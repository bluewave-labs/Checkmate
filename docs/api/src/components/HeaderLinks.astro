---
// Renders next to the search/theme controls in Starlight's header.
// Adds a "Releases" link plus delegates to the default SocialIcons.
import Default from "@astrojs/starlight/components/SocialIcons.astro";
---

<a class="header-link" href="/docs/releases">Releases</a>
<Default><slot /></Default>

<style>
.header-link {
	color: var(--sl-color-white);
	font-size: var(--sl-text-sm);
	font-weight: 500;
	text-decoration: none;
	padding: 0.4rem 0.75rem;
	border-radius: 0.375rem;
	transition: background-color 0.15s ease;
}
.header-link:hover {
	background-color: var(--sl-color-gray-5);
}
:global([data-theme="light"]) .header-link {
	color: var(--sl-color-gray-6);
}
:global([data-theme="light"]) .header-link:hover {
	background-color: var(--sl-color-gray-1);
}
</style>
