{
	"compilerOptions": {
		"rootDir": "./src",
		"allowJs": true,
		"checkJs": false,
		"paths": {
			"@/*": ["./src/*"] // allows "@/db" -> "./src/db"
		},
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"skipLibCheck": true,
		"noUncheckedIndexedAccess": true
	},
	"include": ["src"],
	"exclude": ["tests", "dist", "node_modules"]
}
